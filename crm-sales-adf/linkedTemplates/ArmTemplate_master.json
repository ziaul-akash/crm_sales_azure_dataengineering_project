{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "crm-sales-adf"
		},
		"ls_FileLocation_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'ls_FileLocation'"
		},
		"ls_sinkDataToAdls2_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'ls_sinkDataToAdls2'"
		},
		"ls_FileLocation_properties_typeProperties_host": {
			"type": "string",
			"defaultValue": "D:\\AZURE\\CRM_Sales_Azure_Dataengineering_Project"
		},
		"ls_FileLocation_properties_typeProperties_userId": {
			"type": "string",
			"defaultValue": "admin"
		},
		"ls_sinkDataToAdls2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://crmsalesuksouthadls2.dfs.core.windows.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "crm-sales-adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_sinkDataToAdls2_accountKey": {
						"value": "[parameters('ls_sinkDataToAdls2_accountKey')]"
					},
					"ls_FileLocation_password": {
						"value": "[parameters('ls_FileLocation_password')]"
					},
					"ls_sinkDataToAdls2_properties_typeProperties_url": {
						"value": "[parameters('ls_sinkDataToAdls2_properties_typeProperties_url')]"
					},
					"ls_FileLocation_properties_typeProperties_host": {
						"value": "[parameters('ls_FileLocation_properties_typeProperties_host')]"
					},
					"ls_FileLocation_properties_typeProperties_userId": {
						"value": "[parameters('ls_FileLocation_properties_typeProperties_userId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}